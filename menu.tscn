[sub_resource type="GDScript" id="GDScript_x0sin"]
resource_name = "menu"
script/source = "@tool
extends Node2D

@onready var failed_node = $Failed
@onready var retry_button = $Failed/Retry

@onready var complate_node = $Complete
@onready var complate_button = $Complete/Next

@onready var fail_sound = $FAIL
@onready var success_sound = $SUCCESS

@onready var swoosh = $SWOOSH
@onready var swoosh2 = $SWOOSH_END

@onready var music = $MUSIC

signal retry_action
signal next_action

@export var failed: bool = false:
	set(value):
		failed = value
		if failed_node:
			failed_node.visible = value
		if value == true:
			fail_sound.play();
			
@export var completed: bool = false:
	set(value):
		completed = value
		if complate_node:
			complate_node.visible = value
		if value == true:
			success_sound.play();

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	retry_button.pressed.connect(_on_retry_pressed)
	complate_button.pressed.connect(_on_complete_pressed)
	swoosh.play();
	music.set_pitch_scale(remap(DragDropController.current_level, 0, 5, 1.0, 1.4)  )
	music.play();
	
	pass # Replace with function body.


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	pass
	

func _on_retry_pressed() -> void:
	retry_action.emit()
	pass
	
func _on_complete_pressed() -> void:
	swoosh2.play();
	next_action.emit()
"

